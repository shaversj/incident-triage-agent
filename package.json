{
  "name": "incident-triage-agent",
  "version": "0.1.0",
  "description": "A proof of concept for bounded LLM-assisted incident triage.",
  "type": "module",
  "private": true,
  "scripts": {
    "triage": "bun run src/cli.ts",
    "list": "bun run src/cli.ts list",
    "serve": "bun run src/cli.ts serve",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli.ts --target=bun --outdir=dist",
    "demo-live": "bun run scripts/run-live-e2e-probe.ts"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
