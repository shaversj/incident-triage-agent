{
  "name": "incident-triage-agent",
  "version": "0.1.0",
  "description": "A proof of concept for bounded LLM-assisted incident triage.",
  "type": "module",
  "private": true,
  "scripts": {
    "triage": "tsx src/cli.ts",
    "list": "tsx src/cli.ts list",
    "serve": "tsx src/cli.ts serve",
    "synthetic-service": "tsx services/synthetic-checkout-service.ts",
    "test": "vitest run",
    "evals": "vitest run --config evals/vitest.evals.config.ts",
    "evals:json": "mkdir -p eval-results && vitest run --config evals/vitest.evals.config.ts --reporter=vitest-evals/reporter --reporter=json --outputFile.json=eval-results/vitest-results.json",
    "evals:ui": "vitest-evals serve eval-results",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "demo-live": "tsx scripts/run-live-e2e-probe.ts"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.1",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vitest-evals": "^0.13.1"
  }
}
